{
  "mcpServers": {
    "agentforge-design-agent": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://design-agent-mcp-kri6xyjbwa-uk.a.run.app/mcp",
        "--header",
        "Authorization: Bearer ${AGENTFORGE_API_KEY}"
      ],
      "env": {
        "AGENTFORGE_API_KEY": "YOUR_CLOUD_RUN_API_KEY"
      }
    }
  }
}
