{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentForge Design Contract",
  "description": "Machine-readable design contract derived from design-contract.md by validate_contract. Cosign-signed (Enterprise). Consumed by /implement.",
  "type": "object",
  "required": ["metadata", "pattern_composition", "adk_agent_tree", "tool_bindings", "data_flows", "sequence_summary", "infra_modules", "agent_identity_config", "screening_config"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "version", "use_case", "generated_by", "source_hash", "diagram_tool"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "use_case": { "type": "string" },
        "team": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "generated_by": { "type": "string", "enum": ["validate_contract"], "description": "Always 'validate_contract' — .json is never generated by /design" },
        "source_hash": { "type": "string", "description": "SHA-256 of (design-contract.md + diagram file). Used by /implement to detect staleness." },
        "diagram_tool": { "type": "string", "enum": ["drawio", "eraserio", "svg"], "description": "Developer's chosen diagram tool from plan.md" }
      }
    },
    "pattern_composition": {
      "type": "object",
      "properties": {
        "root_pattern": { "type": "string" },
        "composition": { "type": "array", "items": { "type": "string" } }
      }
    },
    "adk_agent_tree": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "role"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["LlmAgent", "SequentialAgent", "ParallelAgent", "LoopAgent"] },
          "role": { "type": "string" },
          "parent": { "type": ["string", "null"] },
          "model": { "type": "string" },
          "tools": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "tool_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "assigned_to"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["mcp_server", "a2a_agent", "function_tool"] },
          "endpoint": { "type": "string" },
          "auth_method": { "type": "string" },
          "assigned_to": { "type": "string" },
          "agent_card_url": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "discovered_via": { "type": "string" },
          "confidence": { "type": "number" }
        }
      }
    },
    "data_flows": {
      "type": "array",
      "description": "Derived from §3 STL Data Flows table. Used by validate_contract to cross-check diagram edges.",
      "items": {
        "type": "object",
        "required": ["from", "to", "data", "protocol"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "data": { "type": "string" },
          "protocol": { "type": "string", "enum": ["HTTP", "MCP", "A2A", "internal"] }
        }
      }
    },
    "sequence_summary": {
      "type": "array",
      "description": "Derived from §3 STL Sequence Summary. Ordered steps describing end-to-end flow.",
      "items": { "type": "string" }
    },
    "skill_references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "sha": { "type": "string" },
          "assigned_to": { "type": "string" }
        }
      }
    },
    "mcp_server_configs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "auth_method": { "type": "string" },
          "endpoint": { "type": "string" },
          "timeout": { "type": "string" },
          "retry": { "type": "integer" }
        }
      }
    },
    "infra_modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "version": { "type": "string" },
          "component": { "type": "string" },
          "dr_aware": { "type": "boolean" }
        }
      }
    },
    "business_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "condition": { "type": "string" },
            "action": { "type": "string" },
            "else_action": { "type": "string" }
          }
        }
      }
    },
    "agent_identity_config": {
      "type": "array",
      "description": "Per-agent least-privilege — derived from §3 topology + §5 tool bindings",
      "items": {
        "type": "object",
        "required": ["agent_name", "capabilities", "denied"],
        "properties": {
          "agent_name": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "denied": { "type": "array", "items": { "type": "string" } },
          "delegation": { "type": "array", "items": { "type": "string" } },
          "data_classification": { "type": "string" }
        }
      }
    },
    "screening_config": {
      "type": "object",
      "properties": {
        "agents_with_input_screening": { "type": "array", "items": { "type": "string" } },
        "agents_with_output_screening": { "type": "array", "items": { "type": "string" } },
        "pii_fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "golden_dataset": {
      "type": "object",
      "properties": {
        "entries": { "type": "array", "items": { "type": "object" } },
        "min_count_per_agent": { "type": "integer" }
      }
    },
    "eval_config": {
      "type": "object",
      "properties": {
        "frequency": { "type": "string" },
        "hitl_reviewers": { "type": "integer" }
      }
    },
    "nfrs": { "type": "array", "items": { "type": "object" } },
    "cosign_signature": { "type": "string", "description": "cosign signature covering bundle hash (.md + diagram file + .json)" },
    "blueprint_hash": { "type": "string", "description": "SHA-256 of design-contract.md at signing time" },
    "binary_auth_attestation_id": { "type": "string" }
  }
}
